# =====================================================================
#  ちば営業朝刊 環境変数サンプル
#  このファイルを .env にコピーして値を埋めてください（.env はコミット禁止）
#    cp .env.example .env
# =====================================================================

# ---- LINE Messaging API ----------------------------------------------
# LINE Developers コンソール > Messaging API チャネル > チャネルアクセストークン（長期）
LINE_CHANNEL_ACCESS_TOKEN=

# チャネルシークレット（任意）。設定すると Webhook 受信時に署名検証を行う。
# scripts/line_webhook.py で userId を取得する際は未設定でも動く。
LINE_CHANNEL_SECRET=

# Webhook 受信サーバ（scripts/line_webhook.py）の待受設定（任意）
LINE_WEBHOOK_PORT=8000
LINE_WEBHOOK_PATH=/callback

# ---- Stripe ----------------------------------------------------------
# Stripe ダッシュボード > 開発者 > APIキー（シークレットキー sk_live_... / sk_test_...）
STRIPE_API_KEY=

# 配信前に Stripe で「有効なサブスク契約」を毎回チェックするか
#   true  : 各購読者の stripe_customer_id をライブ照会して支払い済みのみ配信
#   false : CSV/Sheets の paid 列だけで判定（Stripe 照会しない）
REQUIRE_STRIPE_PAID=false

# 有効とみなす Stripe サブスクのステータス（カンマ区切り）
STRIPE_ACTIVE_STATUSES=active,trialing

# ---- AI（Claude / Anthropic）-----------------------------------------
# https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# 原稿生成に使うモデル（既定: claude-opus-4-8 / コスト優先なら claude-sonnet-4-6）
AI_MODEL=claude-opus-4-8

# ---- 購読者ソース ----------------------------------------------------
# csv または google_sheets
SUBSCRIBER_SOURCE=csv

# CSV を使う場合のパス（既定: data/subscribers.csv）
SUBSCRIBER_CSV_PATH=data/subscribers.csv

# Google Sheets を使う場合のみ設定
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_WORKSHEET=subscribers
GOOGLE_SERVICE_ACCOUNT_JSON=google_service_account.json

# ---- ネタ収集・採点・原稿生成 ----------------------------------------
# 有効にするソース（カンマ区切り）
ENABLED_SOURCES=prtimes,prefecture,city,tourism,commerce

# 各ソースのフィードURL（JSON）。PR TIMES 以外（県・市・観光・商業）は
# ここでRSS/AtomのURLを設定して有効化する。実URLは各サイトで確認すること。
# 例: SOURCE_FEED_OVERRIDES={"prefecture":"https://www.pref.chiba.lg.jp/.../rss.xml","city:千葉市":"https://www.city.chiba.jp/.../rss.xml"}
SOURCE_FEED_OVERRIDES=

# 原稿候補にする合計点(0〜30)のしきい値
SCORE_THRESHOLD=20

# 採点モード: heuristic（既定・無料・決定的） / ai（Claudeで採点）
SCORING_MODE=heuristic

# 自動生成の文字量（800 / 1000 / 1200）
DRAFT_LENGTH_DEFAULT=1000

# 追加で必ず除外したいキーワード（カンマ区切り）
EXCLUDE_KEYWORDS_EXTRA=

# テスト配信の送信先（自分のLINE userId）。管理画面の「テスト配信」で使用
LINE_TEST_USER_ID=

# ---- 配信メタ情報 ----------------------------------------------------
# タイムゾーン（cron / 「今日」の判定に使用）
TIMEZONE=Asia/Tokyo
